  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SelfStorage",
        "@id": "https://vernalfortknoxselfstorage.com/#business",
        "name": "Fort Knox Self Storage",
        "url": "https://vernalfortknoxselfstorage.com",
        "telephone": "+14358287710",
        "email": "james.richard500@gmail.com",
        "image": "https://vernalfortknoxselfstorage.com/pictures/fortknoxlogo.webp",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "2225 South 3250 East",
          "addressLocality": "Vernal",
          "addressRegion": "UT",
          "postalCode": "84078",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 40.4555,
          "longitude": -109.5287
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "00:00",
          "closes": "23:59"
        },
        "priceRange": "$100–$230/month",
        "areaServed": [
          { "@type": "City", "name": "Vernal" },
          { "@type": "City", "name": "Naples" },
          { "@type": "City", "name": "Jensen" },
          { "@type": "City", "name": "Roosevelt" }
        ]
      },
      {
        "@type": "Service",
        "@id": "https://vernalfortknoxselfstorage.com/parking.html#service",
        "name": "RV, Boat &amp; Vehicle Outdoor Parking — Vernal, Utah",
        "description": "Secure outdoor parking for RVs, motorhomes, boats, campers, cars, trucks, ATVs, UTVs, trailers, and commercial vehicles in Vernal, Utah. Gated facility with 24/7 access. $100/month flat rate.",
        "provider": { "@id": "https://vernalfortknoxselfstorage.com/#business" },
        "areaServed": { "@type": "City", "name": "Vernal" },
        "offers": {
          "@type": "Offer",
          "name": "Outdoor Vehicle &amp; RV Parking",
