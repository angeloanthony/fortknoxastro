        }
      },
      {
        "@type": "Person",
        "@id": "https://vernalfortknoxselfstorage.com/#owner",
        "name": "James Richards",
        "jobTitle": "Owner &amp; Manager",
        "telephone": "+14358287710",
        "worksFor": { "@id": "https://vernalfortknoxselfstorage.com/#business" }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much does RV or boat storage cost in Vernal, Utah?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fort Knox Self Storage charges a flat $100 per month for outdoor parking of RVs, boats, campers, and vehicles in Vernal, Utah. No hidden fees. Call James at 435-828-7710 for availability."
            }
          },
          {
            "@type": "Question",
            "name": "Can I store my RV or boat near Vernal, Utah?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Fort Knox Self Storage at 2225 South 3250 East, Vernal UT offers secure outdoor parking for RVs, motorhomes, boats, campers, trailers, and vehicles. Call James Richards at 435-828-7710 to check availability."
            }
          },
          {
            "@type": "Question",
            "name": "Is RV and boat storage available with 24/7 access near Vernal?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Fort Knox Self Storage offers 24/7 access to the parking facility via a personal access code. There are no restricted hours."
            }
          },
          {
            "@type": "Question",
            "name": "What types of vehicles can I park at Fort Knox Self Storage?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fort Knox accepts RVs, motorhomes, travel trailers, fifth wheels, boats, jet skis, campers, cars, trucks, ATVs, UTVs, motorcycles, horse trailers, utility trailers, and commercial work vehicles."
            }
          }
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vernalfortknoxselfstorage.com/" },
          { "@type": "ListItem", "position": 2, "name": "Auto/RV/Boat Parking", "item": "https://vernalfortknoxselfstorage.com/parking.html" }
        ]
      }
    ]
  }
  </script>

  <style>
    /* ─── Page Summary Block ─── */
    .page-summary-wrap {
      background: rgba(218,165,32,0.15);
      border-left: 5px solid var(--accent-color);
      padding: 16px 22px;
      margin: 24px 0 0;
      border-radius: 0 6px 6px 0;
    }
    .page-summary {
      font-family: 'Open Sans', sans-serif;
      font-size: 1.05rem;
      line-height: 1.65;
      color: var(--white);
      margin: 0;
    }
    .page-summary a { color: var(--accent-color); text-decoration: underline; }
    .page-summary-meta {
      font-family: 'Open Sans', sans-serif;
      font-size: 0.75rem;
      color: rgba(255,255,255,0.45);
      margin-top: 6px;
      display: block;
    }

    /* ─── Breadcrumb ─── */
    .breadcrumb {
      font-family: 'Open Sans', sans-serif;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.6);
      margin-bottom: 16px;
      text-align: center;
    }
    .breadcrumb a { color: var(--accent-color); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span { margin: 0 6px; }

    /* ─── Pricing badge ─── */
    .pricing-badge {
      display: inline-block;
      background: var(--accent-color);
      color: var(--primary-dark);
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 1.6rem;
      padding: 14px 32px;
      border-radius: 50px;
      border: 4px solid var(--primary-dark);
      margin: 20px 0 0;
      box-shadow: 0 4px 0 rgba(0,0,0,0.3), 0 8px 20px rgba(0,0,0,0.3);
      letter-spacing: 1px;
    }

    /* ─── What we can park grid ─── */
    .vehicle-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
    }
    .vehicle-card {
      background: #FFF8DC url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 400px;
      border: 3px solid var(--primary-dark);
      border-radius: 6px;
      padding: 22px 18px;
      text-align: center;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }
    .vehicle-card:hover {
      transform: translateY(-4px);
      border-color: var(--accent-color);
    }
    .vehicle-card .v-icon { font-size: 2.4rem; margin-bottom: 10px; display: block; }
    .vehicle-card h3 {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.92rem;
      font-weight: 700;
      color: var(--primary-dark);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }
    .vehicle-card p {
      font-family: 'Open Sans', sans-serif;
      font-size: 0.87rem;
      color: var(--text-dark);
      line-height: 1.55;
      margin: 0;
    }

    /* ─── Pricing table ─── */
    .table-wrap { overflow-x: auto; margin-top: 16px; }
    .pricing-table {
      width: 100%;
      border-collapse: collapse;
      font-family: 'Open Sans', sans-serif;
      font-size: 0.93rem;
    }
    .pricing-table thead { background: var(--primary-dark); color: var(--white); }
    .pricing-table thead th { padding: 13px 18px; text-align: left; }
    .pricing-table tbody tr:nth-child(even) { background: rgba(222,184,135,0.3); }
    .pricing-table tbody td { padding: 11px 18px; border-bottom: 1px solid rgba(101,67,33,0.15); }
    .pricing-table strong { color: var(--primary-dark); }
    .check { color: #2E7D32; font-weight: bold; }

    /* ─── Benefits list ─── */
    .benefits-list {
      list-style: none;
      padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 18px;
    }
    .benefits-list li {
      background: #FFF8DC url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 400px;
      border: 3px solid var(--primary-dark);
      border-left: 5px solid var(--accent-color);
      border-radius: 0 6px 6px 0;
      padding: 18px 20px;
      font-family: 'Open Sans', sans-serif;
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.65;
    }
    .benefits-list li strong {
      font-family: 'Montserrat', sans-serif;
      color: var(--primary-dark);
      display: block;
      margin-bottom: 4px;
    }

    /* ─── FAQ accordion ─── */
    .faq-accordion details {
      background: #FFF8DC url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 400px;
      border: 3px solid var(--primary-dark);
      border-radius: 6px;
      margin-bottom: 12px;
      box-shadow: var(--shadow-sm);
    }
    .faq-accordion details[open] { border-color: var(--accent-color); }
    .faq-accordion summary {
      padding: 17px 54px 17px 20px;
      cursor: pointer;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.97rem;
      font-weight: 700;
      color: var(--primary-dark);
      list-style: none;
      position: relative;
      line-height: 1.4;
    }
    .faq-accordion summary::-webkit-details-marker { display: none; }
    .faq-accordion summary::after {
      content: '+';
      position: absolute; right: 16px; top: 50%;
      transform: translateY(-50%);
      width: 28px; height: 28px;
      background: var(--accent-color);
      color: var(--primary-dark);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; font-weight: 300;
      box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    }
    .faq-accordion details[open] summary::after {
      content: '−';
      background: var(--primary-dark);
      color: var(--accent-color);
    }
    .faq-answer {
      padding: 16px 20px 20px;
      border-top: 2px dashed rgba(101,67,33,0.25);
      font-family: 'Open Sans', sans-serif;
      font-size: 0.93rem;
      line-height: 1.7;
      color: var(--text-dark);
    }
    .faq-answer p { margin-bottom: 8px; }
    .faq-answer p:last-child { margin: 0; }
    .faq-answer a { color: var(--primary-dark); font-weight: 700; text-decoration: underline; }
    .faq-answer strong { color: var(--primary-dark); }
    .faq-answer .answer-cta {
      display: inline-block; margin-top: 10px;
      background: var(--accent-color); color: var(--primary-dark);
      font-family: 'Montserrat', sans-serif; font-weight: 700;
      font-size: 0.88rem; padding: 8px 18px; border-radius: 30px;
      border: 2px solid var(--primary-dark); text-decoration: none;
      transition: all 0.2s ease;
    }
    .faq-answer .answer-cta:hover { background: var(--primary-dark); color: var(--accent-color); }

    /* ─── Contact card ─── */
    .contact-card-section {
      padding: 60px 0;
      background: #F5DEB3 url('https://www.transparenttextures.com/patterns/light-wool.png');
    }
    .contact-card-inner {
      max-width: 640px;
      margin: 0 auto;
      background: #FFF8DC url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 400px;
      border: 4px solid var(--primary-dark);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: var(--shadow-md);
    }
    .contact-card-header {
      background: var(--primary-dark);
      padding: 18px 24px;
      border-bottom: 3px solid var(--accent-color);
    }
    .contact-card-header h2 {
      font-family: 'Georgia', serif;
      font-size: 1.3rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin: 0;
    }
    .contact-card-body {
      padding: 28px 24px;
      text-align: center;
    }
    .contact-card-body h3 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.2rem;
      color: var(--primary-dark);
      margin-bottom: 2px;
    }
    .contact-card-body .title {
      font-family: 'Open Sans', sans-serif;
      font-size: 0.82rem;
      color: var(--accent-color);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 16px;
      display: block;
    }
    .contact-card-body p {
      font-family: 'Open Sans', sans-serif;
      font-size: 0.95rem;
      color: var(--text-dark);
      line-height: 1.7;
      margin-bottom: 20px;
    }
    .contact-info { display: flex; flex-direction: column; gap: 10px; align-items: center; }
    .contact-item {
      display: flex; align-items: center; gap: 10px;
      font-family: 'Open Sans', sans-serif; font-size: 0.95rem;
      color: var(--primary-dark); font-weight: 700; text-decoration: none;
      transition: color 0.2s;
    }
    .contact-item:hover { color: var(--accent-color); }

    /* ─── CTA bottom block ─── */
    .cta-block {
      background: #CD853F url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 350px;
      border: 6px solid var(--primary-dark);
      border-radius: 8px;
      padding: 40px 36px;
      text-align: center;
      box-shadow: inset 0 0 20px rgba(0,0,0,0.2), var(--shadow-md);
    }
    .cta-block h2 {
      font-family: 'Georgia', serif;
      font-size: 2rem;
      color: var(--metal-dark);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 12px;
      text-shadow: 1px 1px 3px rgba(218,165,32,0.5);
    }
    .cta-block p {
      font-family: 'Open Sans', sans-serif;
      font-size: 1rem;
      color: var(--metal-dark);
      margin-bottom: 24px;
      line-height: 1.65;
    }
    .cta-block .btn { animation: buttonFlash 1.5s ease-in-out infinite; }
    .cta-block .btn:hover { animation: none; }

    @media (max-width: 768px) {
      .vehicle-grid { grid-template-columns: 1fr 1fr; }
      .benefits-list { grid-template-columns: 1fr; }
      .cta-block { padding: 28px 20px; }
      .cta-block h2 { font-size: 1.5rem; }
    }
    @media (max-width: 420px) {
      .vehicle-grid { grid-template-columns: 1fr; }
    }
  </style>
  </Fragment>

  <!-- ═══ HERO ═══ -->
  <section class="hero" aria-label="RV and boat parking page header">
    <div class="container">
      <div class="hero-content">

        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="index.html">Home</a>
          <span>›</span>
          <span>Auto / RV / Boat Parking</span>
        </nav>

        <!-- PILLAR 3: H1 — one per page, includes primary keyword -->
        <h1 class="hero-title">Secure RV, Boat &amp; Vehicle Storage<br>
          <span style="font-size: 1.4rem; letter-spacing: 1px; font-weight: 400; text-transform: none; font-style: italic;">Vernal, Utah — Uintah Basin</span>
        </h1>
        <p class="hero-subtitle">Protected Outdoor Parking · 24/7 Access · Flat Monthly Rate</p>

        <!-- PILLAR 3: PAGE SUMMARY BLOCK -->
        <div class="page-summary-wrap" role="note" aria-label="Service summary">
          <p class="page-summary">
            <strong>Fort Knox Self Storage</strong> offers secure outdoor parking for RVs, boats, campers, and vehicles
            in <strong>Vernal, Utah</strong>.
            <strong>$100/month</strong> flat rate — no hidden fees.
            Gated facility with <strong>24/7 personal access</strong>.
            Located at <strong>2225 South 3250 East, Vernal UT 84078</strong>.
            Call <a href="tel:4358287710">James at 435-828-7710</a> to check availability.
          </p>
          <span class="page-summary-meta">Last updated: <time datetime="2026-02-01">February 2026</time></span>
        </div>

        <div class="hero-cta" style="margin-top: 24px; flex-direction: column; align-items: center; gap: 12px;">
          <div class="pricing-badge">📍 $100 / Month — Flat Rate</div>
          <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 8px;">
            <a href="tel:4358287710" class="btn btn-primary" style="font-family: 'Montserrat', sans-serif;">
              <span>📞</span> 435-828-7710
            </a>
            <a href="#parking-options" class="btn btn-secondary" style="font-family: 'Montserrat', sans-serif;">
              <span>🚐</span> View Options
            </a>
          </div>
        </div>

      </div>
    </div>
    <div class="hero-overlay"></div>
  </section>


  <!-- ═══ WHY PARK WITH US ═══ -->
  <section class="features" aria-labelledby="why-heading">
    <div class="container">
      <h2 id="why-heading" class="section-title">Why Park With Fort Knox?</h2>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3>Gated &amp; Secure</h3>
          <p>Personal access codes for entry — only authorized customers get in. Your vehicle is protected around the clock.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🅿️</div>
          <h3>Spacious Spots</h3>
          <p>Wide open spaces with room for the largest Class A motorhomes, fifth wheels, and commercial trailers.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🌤️</div>
          <h3>Open-Air Parking</h3>
          <p>Secure outdoor lot — easy to pull in and pull out any size rig without maneuvering in tight indoor spaces.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🕐</div>
          <h3>24/7 Access</h3>
          <p>No restricted hours, no holidays off. Get to your RV or boat any time of day or night with your personal code.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <h3>$100 Flat Rate</h3>
          <p>One simple monthly price — $100. No surprise fees, no seasonal surcharges. Price quoted is price charged.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">📞</div>
          <h3>Local Owner</h3>
          <p>Call James Richards directly at <a href="tel:4358287710" style="color: var(--primary-dark); font-weight: bold;">435-828-7710</a> — available 24/7, not a corporate call center.</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══ WHAT WE CAN PARK ═══ -->
  <section id="parking-options" style="padding: 70px 0; background: #E8D5B7 url('https://www.transparenttextures.com/patterns/light-wool.png');" aria-labelledby="vehicles-heading">
    <div class="container">
      <h2 id="vehicles-heading" class="section-title">Vehicles We Accept</h2>
      <div class="vehicle-grid">

        <div class="vehicle-card">
          <span class="v-icon">🚐</span>
          <h3>RVs &amp; Motorhomes</h3>
          <p>Class A, B &amp; C motorhomes, travel trailers, fifth wheels, camper vans, and pop-ups of all sizes</p>
        </div>

        <div class="vehicle-card">
          <span class="v-icon">⛵</span>
          <h3>Boats &amp; Watercraft</h3>
          <p>Fishing boats, pontoons, ski boats, jet skis, and sailboats — with or without trailers</p>
        </div>

        <div class="vehicle-card">
          <span class="v-icon">🚗</span>
          <h3>Cars &amp; Trucks</h3>
          <p>Classic cars, project vehicles, extra cars, pickup trucks, and commercial vehicles</p>
        </div>

        <div class="vehicle-card">
          <span class="v-icon">🏍️</span>
          <h3>ATVs, UTVs &amp; Motorcycles</h3>
          <p>ATVs, side-by-sides, UTVs, dirt bikes, and motorcycles — popular with Flaming Gorge and Book Cliffs riders</p>
        </div>

        <div class="vehicle-card">
          <span class="v-icon">🚜</span>
          <h3>Work &amp; Commercial Vehicles</h3>
          <p>Contractor trucks, work trailers, equipment haulers, and fleet vehicles for Uintah Basin businesses</p>
        </div>

        <div class="vehicle-card">
          <span class="v-icon">🚛</span>
          <h3>Trailers of All Types</h3>
          <p>Utility trailers, horse trailers, cargo trailers, flatbeds, and equipment trailers</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══ PRICING TABLE ═══ -->
  <section style="padding: 70px 0; background: #F5DEB3 url('https://www.transparenttextures.com/patterns/light-wool.png');" aria-labelledby="pricing-heading">
    <div class="container">
      <h2 id="pricing-heading" class="section-title">Parking Rates — Vernal, Utah</h2>

      <div class="table-wrap">
        <table class="pricing-table">
          <thead>
            <tr>
              <th>Vehicle / Parking Type</th>
              <th>Monthly Rate</th>
              <th>Access</th>
              <th>Security</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>RV / Motorhome</strong> (any class)</td>
              <td><strong>$100/month</strong></td>
              <td class="check">✓ 24/7</td>
              <td class="check">✓ Gated</td>
            </tr>
            <tr>
              <td><strong>Boat</strong> (with or without trailer)</td>
              <td><strong>$100/month</strong></td>
              <td class="check">✓ 24/7</td>
              <td class="check">✓ Gated</td>
            </tr>
            <tr>
              <td><strong>Camper / Travel Trailer / 5th Wheel</strong></td>
