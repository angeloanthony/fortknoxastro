---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout active="parking.html" footerTagline="Your LOCAL source for shipping containers and secure storage serving the Uintah Basin! 📦🏔️">
  <Fragment slot="head">
  <!-- ═══ PILLAR 3: TITLE TAG — 57 chars ═══ -->
  <title>RV Boat & Vehicle Storage Vernal UT | Fort Knox</title>

  <!-- ═══ PILLAR 3: META DESCRIPTION — 157 chars ═══ -->
  <meta name="description" content="Secure outdoor parking for RVs, boats, campers &amp; vehicles in Vernal, Utah. $100/month flat rate. Gated, 24/7 access. Call James Richards: 435-828-7710.">

  <!-- Location Meta -->
  <meta name="geo.region" content="US-UT">
  <meta name="geo.placename" content="Vernal">
  <meta name="geo.position" content="40.4555;-109.5287">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="RV, Boat &amp; Vehicle Storage Vernal UT | Fort Knox Self Storage">
  <meta property="og:description" content="Secure outdoor parking for RVs, boats, campers and vehicles in Vernal, Utah. $100/month. Gated, 24/7 access. Call James: 435-828-7710.">
  <meta property="og:image" content="https://vernalfortknoxselfstorage.com/pictures/fortknoxlogo.webp">
  <meta property="og:url" content="https://vernalfortknoxselfstorage.com/parking.html">

  <!-- Canonical -->
  <link rel="canonical" href="https://vernalfortknoxselfstorage.com/parking.html">

  <!-- ═══ PILLAR 4: SCHEMA MARKUP ═══ -->
