      <div class="hero-content" style="padding-top: 0;">

        <!-- Video + No Fees badge — FIRST: humans see this before anything else -->
        <div style="position: relative; margin-top: 0;">

          <img src="pictures/nofees.webp" alt="No Hidden Fees — Fort Knox Self Storage" style="position: absolute; left: -350px; top: 50%; transform: translateY(-50%); max-width: 300px; height: auto; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">

          <!-- Western-themed video frame -->
          <div class="western-video-container">
            <div class="western-frame">
              <div class="wood-corner top-left"></div>
              <div class="wood-corner top-right"></div>
              <div class="wood-corner bottom-left"></div>
              <div class="wood-corner bottom-right"></div>
              <div class="video-wrapper">
                <iframe
                  width="560" height="315"
                  src="https://www.youtube.com/embed/trKiDR09-pU?si=sYHgHkd3HkNXKctj"
                  title="Fort Knox Self Storage Vernal Utah — Facility Tour"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen loading="lazy">
                </iframe>
              </div>
            </div>
          </div>

        </div>

        <!-- ═══ PILLAR 3: H1 — kept in HTML for Google, sits below video visually ═══ -->
        <h1 class="hero-title">Storage Units in Vernal, Utah — Mouse-Proof Steel Containers with 24/7 Access</h1>

        <!-- Promotional Banner -->
        <div class="promo-banner">
          <img src="pictures/banner1.webp" alt="Rent Free for Two Months with Six Months Contract" style="width: 100%; max-width: 800px; height: auto; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); display: block; margin: 0 auto;">
        </div>

        <!-- ═══ SEO BLOCKS — invisible to humans, fully readable by Google/AI crawlers ═══ -->
        <div class="seo-only" aria-hidden="true">

          <!-- PAGE SUMMARY BLOCK — AI crawlers prioritize this -->
          <div class="page-summary-wrap" role="note" aria-label="Business summary">
            <p class="page-summary">
              <strong>Fort Knox Self Storage</strong> provides secure, mouse-proof storage units in <strong>Vernal, Utah</strong>.
              20ft containers starting at <strong>$130/month</strong> · 40ft containers at <strong>$230/month</strong>.
              24/7 access · fire detection · no hidden fees · first 2 months FREE with a 6-month contract.
              Located at <strong>2225 South 3250 East, Vernal, UT 84078</strong>.
              Call <a href="tel:4358287710">James Richards at 435-828-7710</a> to reserve today.
            </p>
            <span class="page-summary-meta">Last updated: <time datetime="2026-02-28">February 2026</time></span>
          </div>

          <!-- VOICE ANSWER BLOCK (speakable) -->
          <div class="voice-answer-block">
            <p>
              <strong>Looking for storage units in Vernal?</strong>
              Fort Knox Self Storage offers secure, mouse-proof storage units starting at $130 per month.
              We have 20-foot and 40-foot units available with 24/7 access.
              Call James at 435-828-7710 to reserve your unit today.
            </p>
          </div>

        </div><!-- /.seo-only -->

        <!-- Container size quick answers -->
        <section class="quick-answers" aria-label="Storage container sizes">
          <h2>We offer 20ft and 40ft long mouse-proof storage units</h2>
          <ul>
            <li><strong><a href="container-sales.html">40ft Mouse-Proof Storage Unit</a>:</strong> Holds the contents of a normal-sized home and garage.</li>
            <li><strong><a href="container-sales.html">20ft Mouse-Proof Storage Unit</a>:</strong> Holds the goods of a typical apartment.</li>
          </ul>
          <p><a href="parking.html">We also offer <strong>Parking Spaces</strong> for Cars, Trucks, RVs, Boats, Campers, Motorhomes, etc.</a></p>
        </section>

        <!-- CTA Button -->
        <div class="hero-cta" style="display: flex; flex-direction: column; align-items: center; gap: 14px;">
          <p style="color: var(--accent-color); font-size: 1.5rem; font-weight: 700; margin-bottom: 0; text-shadow: 3px 3px 6px rgba(0,0,0,0.8);">
            Click To Dial
          </p>
          <a href="tel:4358287710" class="btn btn-primary" style="font-family: 'Montserrat', sans-serif;">
            <span>📞</span> <span style="font-weight: 900;">435-828-7710</span>
          </a>
          <!-- ★ REVIEW BUTTONS ★ -->
          <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; width: 100%; max-width: 400px;">
            <a href="https://g.page/r/CSmK2QrCv3uxEBM/review"
               target="_blank" rel="noopener"
               style="flex: 1; min-width: 160px; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
                      background: #DAA520; color: #fff; font-family: 'Montserrat', sans-serif; font-weight: 800;
                      font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px; text-decoration: none;
                      padding: 14px 18px; border-radius: 50px; border: 3px solid #DAA520;
                      box-shadow: 0 4px 14px rgba(0,0,0,0.3); transition: transform 0.2s, box-shadow 0.2s;"
               onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 20px rgba(0,0,0,0.35)'"
               onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 14px rgba(0,0,0,0.3)'"
               aria-label="Write a Google review for Fort Knox Self Storage">
              ✍️ Write a Review
            </a>
            <a href="https://www.google.com/maps?cid=12789026406975244841"
               target="_blank" rel="noopener"
               style="flex: 1; min-width: 160px; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
                      background: transparent; color: #DAA520; font-family: 'Montserrat', sans-serif; font-weight: 800;
                      font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px; text-decoration: none;
                      padding: 14px 18px; border-radius: 50px; border: 3px solid #DAA520;
                      box-shadow: 0 4px 14px rgba(0,0,0,0.3); transition: transform 0.2s, box-shadow 0.2s;"
               onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 20px rgba(0,0,0,0.35)'"
               onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 14px rgba(0,0,0,0.3)'"
               aria-label="Read Google reviews for Fort Knox Self Storage">
              ★★★★★ Read Reviews
            </a>
          </div>
        </div>

      </div>
    </div>
    <div class="hero-overlay"></div>
  </section>


  <!-- ═══════════════════════════════════════════
