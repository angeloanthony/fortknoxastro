          "@type": "OfferCatalog",
          "name": "Storage Unit Options",
          "itemListElement": [
            {
              "@type": "Offer",
              "name": "20ft Mouse-Proof Storage Container",
              "price": "130",
              "priceCurrency": "USD",
              "description": "20-foot steel storage container, mouse-proof. Holds contents of a typical apartment. 24/7 access."
            },
            {
              "@type": "Offer",
              "name": "40ft Mouse-Proof Storage Container",
              "price": "230",
              "priceCurrency": "USD",
              "description": "40-foot steel storage container, mouse-proof. Holds contents of a full home and garage. 24/7 access."
