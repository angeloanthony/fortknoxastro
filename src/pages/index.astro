---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout active="index.html">
  <Fragment slot="head">
  <!-- ═══ PILLAR 3: TITLE TAG — "storage units" matches top query pattern ═══ -->
  <title>Storage Units in Vernal UT | Fort Knox Self Storage</title>

  <!-- ═══ PILLAR 3: META DESCRIPTION — leads with FREE offer, then features ═══ -->
  <meta name="description" content="🆓 First 2 Months FREE · Mouse-Proof Storage Units from $130/mo · 24/7 Access · No Hidden Fees · Vernal, UT 84078 · Call James: 435-828-7710">

  <!-- Location Meta -->
  <meta name="geo.region" content="US-UT">
  <meta name="geo.placename" content="Vernal">
  <meta name="geo.position" content="40.4237;-109.4672">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Storage Units in Vernal UT | Fort Knox Self Storage">
  <meta property="og:description" content="First 2 Months FREE · Mouse-Proof Storage Units from $130/mo · 24/7 Access · No Hidden Fees · Vernal, Utah · Call James: 435-828-7710.">
  <meta property="og:image" content="https://vernalfortknoxselfstorage.com/pictures/fortknoxlogo.webp">
