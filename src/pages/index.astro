            </tr>
            <tr>
              <td style="padding: 15px; border: 1px solid #ddd; font-weight: 600;">24/7 Access</td>
              <td style="padding: 15px; border: 1px solid #ddd; text-align: center; color: green; font-size: 1.2rem;">✓ Yes</td>
