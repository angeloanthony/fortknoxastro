        "email": "james.richard500@gmail.com",
        "description": "James Richards is the owner and manager of Fort Knox Self Storage in Vernal, Utah. A local Vernal resident, James is available 24/7 and provides the most affordable mouse-proof and fireproof storage in the Uintah Basin.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Vernal",
          "addressRegion": "UT"
        },
        "worksFor": { "@id": "https://vernalfortknoxselfstorage.com/#business" }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much does storage cost in Vernal, Utah?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fort Knox Self Storage offers 20-foot mouse-proof containers starting at $130/month and 40-foot containers at $230/month. There are no hidden fees. New customers signing a 6-month agreement receive the first 2 months completely free. Call James at 435-828-7710."
            }
          },
          {
            "@type": "Question",
            "name": "Where is the nearest storage facility in Vernal?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fort Knox Self Storage is located at 2225 South 3250 East, Vernal, Utah 84078 — just south of Naples. Convenient for residents in Vernal, Jensen, Naples, Maeser, and Roosevelt throughout the Uintah Basin."
