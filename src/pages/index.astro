        "url": "https://vernalfortknoxselfstorage.com",
        "telephone": "+14358287710",
        "email": "james.richard500@gmail.com",
        "description": "Fort Knox Self Storage in Vernal, Utah offers secure, mouse-proof, fireproof steel storage units with 24/7 access. 20ft containers from $130/month, 40ft from $230/month. No hidden fees.",
        "image": [
          "https://vernalfortknoxselfstorage.com/pictures/fortknoxlogo.webp",
          "https://vernalfortknoxselfstorage.com/pictures/HighSecurity02.webp"
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "2225 South 3250 East",
          "addressLocality": "Vernal",
          "addressRegion": "UT",
          "postalCode": "84078",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 40.4237,
          "longitude": -109.4672
        },
        "hasMap": "https://maps.google.com/?q=Fort+Knox+Self+Storage+Vernal+Utah",
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "00:00",
          "closes": "23:59",
          "description": "Storage Access Available 24/7"
        },
        "priceRange": "$130–$230/month",
        "areaServed": [
          { "@type": "City", "name": "Vernal" },
          { "@type": "City", "name": "Naples" },
          { "@type": "City", "name": "Jensen" },
          { "@type": "City", "name": "Roosevelt" },
          { "@type": "City", "name": "Maeser" }
        ],
        "amenityFeature": [
          { "@type": "LocationFeatureSpecification", "name": "24/7 Access", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "Fire Detection System", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "Mouse-Proof Containers", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "Spider-Proof Containers", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "RV Parking", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "Boat Parking", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "No Hidden Fees", "value": true }
        ],
