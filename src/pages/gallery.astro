      <div class="carousel-dots" id="dots" role="tablist" aria-label="Slide navigation"></div>
    </div>
  </section>


  <!-- ═══ FEATURE HIGHLIGHTS ═══ -->
  <section class="highlights-section" aria-labelledby="highlights-heading">
    <div class="container">
      <h2 id="highlights-heading" class="section-title">What You See Is What You Get</h2>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon">📏</div>
          <h3>Huge Capacity</h3>
          <p>40ft × 9ft containers hold an entire home's worth of belongings plus garage items. 20ft units available for smaller needs.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3>High-Security Steel Doors</h3>
          <p>Industrial-strength steel doors with heavy-duty locks. Each container is sealed — no gaps, no entry points for pests or intruders.</p>
