---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout active="gallery.html" footerTagline="Your LOCAL source for shipping containers and secure storage serving the Uintah Basin! 📦🏔️">
  <Fragment slot="head">
  <title>Photo Gallery | Fort Knox Self Storage Vernal UT</title>
  <meta name="description" content="See real photos of Fort Knox Self Storage in Vernal, Utah. Steel containers, wide driveways, drive-up access &amp; 24/7 security. Call James: 435-828-7710.">

  <!-- Location Meta -->
  <meta name="geo.region" content="US-UT">
  <meta name="geo.placename" content="Vernal">
  <meta name="geo.position" content="40.4237;-109.4672">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Photo Gallery | Fort Knox Self Storage Vernal UT">
  <meta property="og:description" content="Real photos of Fort Knox Self Storage in Vernal, Utah — steel containers, wide driveways, drive-up access, and 24/7 security. Call James Richards: 435-828-7710.">
  <meta property="og:image" content="https://vernalfortknoxselfstorage.com/pictures/fortknox2.webp">
  <meta property="og:url" content="https://vernalfortknoxselfstorage.com/gallery.html">

  <link rel="canonical" href="https://vernalfortknoxselfstorage.com/gallery.html">

  <script type="application/ld+json">
