        "@type": "SelfStorage",
        "@id": "https://vernalfortknoxselfstorage.com/#business",
        "name": "Fort Knox Self Storage",
        "url": "https://vernalfortknoxselfstorage.com",
        "telephone": "+14358287710",
        "email": "james.richard500@gmail.com",
        "image": [
          "https://vernalfortknoxselfstorage.com/pictures/fortknox2.webp",
          "https://vernalfortknoxselfstorage.com/pictures/Row40Foot1.webp",
          "https://vernalfortknoxselfstorage.com/pictures/Container01.webp",
          "https://vernalfortknoxselfstorage.com/pictures/ContainerDoorAndLocking.webp",
          "https://vernalfortknoxselfstorage.com/pictures/Deliver02.webp",
          "https://vernalfortknoxselfstorage.com/pictures/Loading.webp",
          "https://vernalfortknoxselfstorage.com/pictures/fortknox1.webp"
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "2225 South 3250 East",
          "addressLocality": "Vernal",
          "addressRegion": "UT",
          "postalCode": "84078",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 40.4237,
          "longitude": -109.4672
        },
        "priceRange": "$130-$230/month"
      },
      {
        "@type": "ImageGallery",
        "@id": "https://vernalfortknoxselfstorage.com/gallery.html#gallery",
        "name": "Fort Knox Self Storage Facility Photos — Vernal, Utah",
        "description": "Photos of Fort Knox Self Storage in Vernal, Utah showing 40ft steel shipping containers, drive-up access, security locks, and the gated facility.",
        "url": "https://vernalfortknoxselfstorage.com/gallery.html",
        "image": [
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/fortknox2.webp", "name": "Fort Knox Self Storage secure facility — Vernal, Utah" },
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/Row40Foot1.webp", "name": "Rows of 40ft storage containers — Fort Knox Vernal UT" },
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/Container01.webp", "name": "Steel shipping container exterior — Fort Knox Self Storage" },
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/ContainerDoorAndLocking.webp", "name": "High-security steel door and locking system — Fort Knox" },
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/Deliver02.webp", "name": "Drive-up access at Fort Knox Self Storage Vernal" },
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/Loading.webp", "name": "Loading containers at Fort Knox Self Storage" },
          { "@type": "ImageObject", "contentUrl": "https://vernalfortknoxselfstorage.com/pictures/fortknox1.webp", "name": "Fort Knox Self Storage facility entrance — Vernal UT" }
