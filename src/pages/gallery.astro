  <!-- Gallery-specific styles (not duplicated in styles.css) -->
  <style>
    .seo-only {
      position: absolute; width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }
    .breadcrumb {
      font-family: 'Open Sans', sans-serif; font-size: 0.85rem;
      color: rgba(255,255,255,0.6); margin-bottom: 16px; text-align: center;
    }
    .breadcrumb a { color: var(--accent-color); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span { margin: 0 6px; }
    .gallery-section {
      padding: 70px 0;
      background: #F5DEB3 url('https://www.transparenttextures.com/patterns/light-wool.png');
    }
    .photo-feature {
      background: #FFF8DC url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 400px; border: 4px solid var(--primary-dark);
      border-radius: 6px; overflow: hidden; box-shadow: var(--shadow-md); margin-bottom: 40px;
    }
    .photo-feature img { width: 100%; height: auto; display: block; object-fit: cover; }
    .photo-feature-caption { padding: 28px 32px; border-top: 3px solid var(--accent-color); }
    .photo-feature-caption h3 {
      font-family: 'Georgia', serif; font-size: 1.4rem; color: var(--primary-dark);
      text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;
    }
    .photo-feature-caption p {
      font-family: 'Open Sans', sans-serif; font-size: 0.95rem;
      color: var(--text-dark); line-height: 1.7; margin: 0 0 8px;
    }
    .photo-feature-caption p:last-child { margin: 0; }
    .photo-feature-caption strong { color: var(--primary-dark); }
    .caption-highlights { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 12px; }
    .caption-tag {
      font-family: 'Montserrat', sans-serif; font-size: 0.8rem; font-weight: 700;
      background: var(--primary-dark); color: var(--accent-color);
      padding: 5px 14px; border-radius: 20px; letter-spacing: 0.5px; text-transform: uppercase;
    }
    .carousel-section {
      padding: 70px 0;
      background: #E8D5B7 url('https://www.transparenttextures.com/patterns/light-wool.png');
    }
    .carousel-container {
      position: relative; max-width: 1000px; margin: 0 auto;
      overflow: hidden; border: 6px solid var(--primary-dark); border-radius: 6px;
      box-shadow: 0 10px 40px rgba(44,24,16,0.4); background: #2C2C2C;
    }
    .carousel-slides { display: flex; transition: transform 0.5s ease-in-out; }
    .carousel-slide { min-width: 100%; position: relative; }
    .carousel-slide img { width: 100%; height: 560px; object-fit: cover; display: block; }
    .carousel-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(44,24,16,0.92), transparent);
      color: var(--accent-color); padding: 36px; text-align: center;
    }
    .carousel-overlay h3 {
      font-family: 'Georgia', serif; font-size: 1.7rem; margin-bottom: 6px;
      text-shadow: 3px 3px 6px rgba(0,0,0,0.9); text-transform: uppercase; letter-spacing: 2px;
    }
    .carousel-overlay p { font-family: 'Open Sans', sans-serif; font-size: 0.95rem; color: rgba(255,255,255,0.85); margin: 0; }
    .carousel-btn {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(139,69,19,0.9); color: var(--accent-color);
      border: 3px solid var(--primary-dark); width: 52px; height: 52px;
      border-radius: 50%; cursor: pointer; font-size: 1.5rem; z-index: 10;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, transform 0.2s;
    }
    .carousel-btn:hover { background: rgba(101,67,33,0.98); transform: translateY(-50%) scale(1.08); }
    .carousel-btn.prev { left: 16px; }
    .carousel-btn.next { right: 16px; }
    .carousel-dots { text-align: center; padding: 20px; background: rgba(139,69,19,0.25); }
    .dot {
      display: inline-block; width: 13px; height: 13px; border-radius: 50%;
      background: #DEB887; margin: 0 7px; cursor: pointer;
      border: 3px solid var(--primary-dark); transition: all 0.3s ease;
    }
    .dot.active { background: var(--accent-color); transform: scale(1.3); }
    .highlights-section {
      padding: 70px 0;
      background: #F5DEB3 url('https://www.transparenttextures.com/patterns/light-wool.png');
    }
    .tour-section {
      padding: 60px 0;
      background: #E8D5B7 url('https://www.transparenttextures.com/patterns/light-wool.png');
    }
    .tour-card-inner {
      max-width: 640px; margin: 0 auto;
      background: #FFF8DC url('https://www.transparenttextures.com/patterns/wood-pattern.png');
      background-size: 400px; border: 4px solid var(--primary-dark);
      border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-md);
    }
    .tour-card-header { background: var(--primary-dark); padding: 18px 24px; border-bottom: 3px solid var(--accent-color); }
    .tour-card-header h2 {
      font-family: 'Georgia', serif; font-size: 1.3rem; color: var(--accent-color);
      text-transform: uppercase; letter-spacing: 1.5px; margin: 0;
    }
    .tour-card-body { padding: 28px 24px; text-align: center; }
    .tour-card-body h3 { font-family: 'Montserrat', sans-serif; font-size: 1.15rem; color: var(--primary-dark); margin-bottom: 2px; }
    .tour-card-body .title {
      font-family: 'Open Sans', sans-serif; font-size: 0.82rem; color: var(--accent-color);
      font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 16px;
    }
    .tour-card-body p { font-family: 'Open Sans', sans-serif; font-size: 0.95rem; color: var(--text-dark); line-height: 1.7; margin-bottom: 20px; }
    .contact-info { display: flex; flex-direction: column; gap: 10px; align-items: center; }
    .contact-item {
      display: flex; align-items: center; gap: 10px;
      font-family: 'Open Sans', sans-serif; font-size: 0.95rem;
      color: var(--primary-dark); font-weight: 700; text-decoration: none; transition: color 0.2s;
    }
    .contact-item:hover { color: var(--accent-color); }
    @media (max-width: 768px) {
      .carousel-slide img { height: 320px; }
      .carousel-btn { width: 40px; height: 40px; font-size: 1.2rem; }
      .carousel-overlay h3 { font-size: 1.2rem; }
      .photo-feature-caption { padding: 20px; }
      .photo-feature-caption h3 { font-size: 1.15rem; }
    }
  </style>
  </Fragment>

  <section class="hero" aria-label="Gallery page header">
    <div class="container">
      <div class="hero-content">

        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="index.html">Home</a><span>›</span><span>Photo Gallery</span>
        </nav>

        <h1 class="hero-title">Fort Knox Self Storage<br>
          <span style="font-size: 1.3rem; font-weight: 400; text-transform: none; font-style: italic; letter-spacing: 1px;">Facility Photos — Vernal, Utah</span>
        </h1>
        <p class="hero-subtitle">Steel Containers · Drive-Up Access · 24/7 Security</p>

        <!-- SEO-only: invisible to humans, readable by Google -->
        <div class="seo-only" aria-hidden="true">
          Real photos of Fort Knox Self Storage in Vernal, Utah. See our 20ft and 40ft steel shipping containers,
          wide gravel driveways, high-security locks, and the full gated facility at 2225 South 3250 East, Vernal UT 84078.
          Call James at 435-828-7710 to schedule a personal tour. Last updated: February 2026.
        </div>

        <div class="hero-cta" style="margin-top: 24px;">
          <a href="tel:4358287710" class="btn btn-primary" style="font-family: 'Montserrat', sans-serif;">
            <span>📞</span> 435-828-7710
          </a>
          <a href="index.html#contact" class="btn btn-secondary" style="font-family: 'Montserrat', sans-serif;">
            <span>📍</span> Visit Us
          </a>
        </div>

      </div>
    </div>
    <div class="hero-overlay"></div>
  </section>


  <!-- ═══ FEATURED PHOTOS — fixed image paths ═══ -->
  <section class="gallery-section" aria-labelledby="gallery-heading">
    <div class="container">
      <h2 id="gallery-heading" class="section-title">Our Facility &amp; Containers</h2>

      <!-- Photo 1 -->
      <div class="photo-feature">
        <img
          src="pictures/Row40Foot1.webp"
          alt="40ft steel storage containers at Fort Knox Self Storage, Vernal Utah — 24/7 drive-up access"
          loading="lazy" width="1200" height="675">
        <div class="photo-feature-caption">
          <h3>40ft Containers — Fits a Full Home &amp; Garage</h3>
          <p>Our <strong>40ft long × 9ft high steel containers</strong> provide enough space to store the entire contents of an average full-size home plus garage. Pull your truck or trailer right up to the door — <strong>24/7, any day of the year</strong>.</p>
          <div class="caption-highlights">
            <span class="caption-tag">40ft × 9ft High</span>
            <span class="caption-tag">Drive-Up Access</span>
            <span class="caption-tag">24/7</span>
            <span class="caption-tag">Mouse-Proof Steel</span>
