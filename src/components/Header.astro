---
// Header.astro — site header + primary navigation.
// Faithfully reproduces the original markup. The `active` prop marks the
// current page's nav link (matching the original per-page `class="active"`),
// and `extraNavLinks` supports the handful of pages that carried an extra
// contextual nav item (e.g. storage-near-me.html).
//
// `active` should be the original HREF of the current page, e.g. "index.html".
//
// ── ACCESSIBILITY CHANGE vs. the original ───────────────────────────────────
// The mobile hamburger was a <div>, which is not focusable or announced to
// screen readers and fails tap-target / mobile-usability audits (the Semrush
// "hard-to-tap buttons" flag). It is now a real <button> with:
//   • type="button"            — won't submit anything
//   • aria-label               — names the control for screen readers
//   • aria-controls="nav"      — associates it with the menu it toggles
//   • aria-expanded            — reflects open/closed state (updated by JS)
// The class names (menu-toggle, its three <span> bars, the .active state) are
// unchanged, so all existing CSS continues to apply with no style edits.

export interface NavLink {
  href: string;
  label: string;
}

interface Props {
  active?: string;
  extraNavLinks?: NavLink[];
}

const { active = "", extraNavLinks = [] } = Astro.props;

// Canonical 7-link navigation, identical to every original page.
const navLinks: NavLink[] = [
  { href: "index.html", label: "Home" },
  { href: "about.html", label: "About" },
  { href: "container-sales.html", label: "Container Sales" },
  { href: "gallery.html", label: "Gallery" },
  { href: "parking.html", label: "Auto/RV/Boat Parking" },
  { href: "reviews.html", label: "Reviews" },
  { href: "faq.html", label: "FAQ" },
];

const allLinks = [...navLinks, ...extraNavLinks];
---

<!-- ═══════════════════════════════════════════
     HEADER — NAP in header (Pillar 1)
═══════════════════════════════════════════ -->
<header class="header">
  <div class="container">
    <div class="header-content">
      <a href="index.html">
        <img src="pictures/fortknoxlogo.webp" alt="Fort Knox Self Storage — Vernal Utah Storage Units" class="logo" width="290" height="290" />
      </a>

      <!-- Hamburger (mobile only) — real <button> for keyboard + screen-reader access -->
      <button
        type="button"
        class="menu-toggle"
        id="menuToggle"
        aria-label="Open navigation menu"
        aria-controls="nav"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="nav" id="nav" aria-label="Main navigation">
        {allLinks.map((link) => (
          <a href={link.href} class={active === link.href ? "active" : undefined}>{link.label}</a>
        ))}
      </nav>
    </div>
  </div>
</header>
