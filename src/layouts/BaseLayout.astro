---
// BaseLayout.astro — the universal page shell for every Fort Knox page.
//
// What the layout OWNS (identical on every original page):
//   - <!doctype html>, <html lang="en">
//   - charset + viewport meta
//   - the global stylesheet (now pipelined via import, not a raw <link>)
//   - the web fonts (now self-hosted via @fontsource, not render-blocking
//     Google Fonts)
//   - the <header> (via Header.astro)
//   - the <footer> (via Footer.astro)
//   - the site JavaScript (via MobileMenuScript.astro)
//
// What each PAGE provides:
//   - head slot: <title>, <meta description>, geo meta, Open Graph, canonical,
//     JSON-LD schema, and any page-specific inline <style> — passed verbatim
//     so all SEO metadata is preserved exactly.
//   - default slot: the unique page body content.
//
// Props let a page set its active nav link, extra nav links, and footer tagline.
//
// ── PERFORMANCE CHANGES vs. the original layout ──────────────────────────────
//  • Removed the render-blocking Google Fonts <link> (preconnect + CSS request
//    to fonts.googleapis.com / fonts.gstatic.com on every page). Fonts are now
//    self-hosted through @fontsource and bundled by Astro — no third-party
//    round trip on the critical path. This is the biggest mobile-score win.
//  • Removed the two raw <link rel="stylesheet"> tags. The merged global.css is
//    now imported, so Astro minifies, fingerprints, and long-caches it under
//    /_astro/* automatically (your _headers rule already covers that path).
//
// SETUP (one time): install the font packages used across the stylesheet —
//     npm install @fontsource/montserrat @fontsource/open-sans
// Montserrat weights used by the CSS: 400, 600, 700, 800. Open Sans: 400, 600.
// We import the LATIN subset only — the site serves Vernal, UT, so the
// cyrillic/greek/vietnamese subsets @fontsource also ships would just bloat the
// build with files no visitor requests. (Browsers gate subsets by unicode-range
// anyway, but latin-only keeps the build output clean.)

import "@fontsource/montserrat/latin-400.css";
import "@fontsource/montserrat/latin-600.css";
import "@fontsource/montserrat/latin-700.css";
import "@fontsource/montserrat/latin-800.css";
import "@fontsource/open-sans/latin-400.css";
import "@fontsource/open-sans/latin-600.css";

import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileMenuScript from "../components/MobileMenuScript.astro";
import type { NavLink } from "../components/Header.astro";

interface Props {
  active?: string;
  extraNavLinks?: NavLink[];
  footerTagline?: string;
}

const { active, extraNavLinks, footerTagline } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Per-page metadata: title, description, geo, Open Graph, canonical, JSON-LD, inline styles -->
  <slot name="head" />
</head>
<body>
  <Header active={active} extraNavLinks={extraNavLinks} />

  <slot />

  <Footer tagline={footerTagline} />

  <MobileMenuScript />
</body>
</html>
